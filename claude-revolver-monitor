#!/usr/bin/env bash
set -euo pipefail

# claude-revolver-monitor — Background usage poller for systemd timer
# Polls OAuth usage API for all stored accounts, updates cache, sends notifications

readonly DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/claude-revolver"
readonly USAGE_CACHE="$DATA_DIR/usage-cache.json"
readonly USAGE_API="https://api.anthropic.com/api/oauth/usage"

# Notification thresholds
readonly WARN_5H=80
readonly WARN_7D=90
readonly CRIT_7D=95

die()  { printf 'claude-revolver-monitor: error: %s\n' "$*" >&2; exit 1; }
log()  { printf 'claude-revolver-monitor: %s\n' "$*" >&2; }

notify() {
    local urgency="$1" title="$2" body="$3"
    if command -v notify-send &>/dev/null; then
        notify-send -u "$urgency" "$title" "$body" 2>/dev/null || true
    fi
    log "$title — $body"
}

command -v jq   &>/dev/null || die "jq not found"
command -v curl &>/dev/null || die "curl not found"
[[ -d "$DATA_DIR" ]] || die "data dir not found: $DATA_DIR"

# Load existing cache or start fresh
if [[ -f "$USAGE_CACHE" ]]; then
    cache=$(cat "$USAGE_CACHE")
else
    cache="{}"
fi

# Iterate over stored accounts
for acct_dir in "$DATA_DIR"/*/; do
    [[ -d "$acct_dir" && -f "$acct_dir/credentials.json" ]] || continue
    name=$(basename "$acct_dir")

    token=$(jq -r '.claudeAiOauth.accessToken // empty' "$acct_dir/credentials.json" 2>/dev/null)
    [[ -n "$token" ]] || continue

    # Fetch usage
    response=$(curl -sf --max-time 10 "$USAGE_API" \
        -H "Authorization: Bearer $token" \
        -H "anthropic-beta: oauth-2025-04-20" 2>/dev/null) || {
        # Check if 401 (token expired)
        http_code=$(curl -so /dev/null -w '%{http_code}' --max-time 10 "$USAGE_API" \
            -H "Authorization: Bearer $token" \
            -H "anthropic-beta: oauth-2025-04-20" 2>/dev/null) || http_code="000"

        if [[ "$http_code" == "401" ]]; then
            cache=$(echo "$cache" | jq --arg name "$name" '
                .[$name] = (.[$name] // {}) + {token_expired: true, polled_at: (now | todate)}
            ')
            notify "critical" "Claude Revolver" "Account '$name' token expired — run 'claude login' to refresh"
        else
            log "failed to fetch usage for '$name' (HTTP $http_code)"
        fi
        continue
    }

    # Parse usage
    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    cache=$(echo "$cache" | jq --arg name "$name" --arg now "$now_iso" --argjson resp "$response" '
        .[$name] = {
            five_hour: $resp.five_hour,
            seven_day: $resp.seven_day,
            seven_day_sonnet: $resp.seven_day_sonnet,
            seven_day_opus: $resp.seven_day_opus,
            token_expired: false,
            polled_at: $now
        }
    ')

    # Check thresholds
    u5=$(echo "$response" | jq -r '.five_hour.utilization // 0')
    u7=$(echo "$response" | jq -r '.seven_day.utilization // 0')
    u5_int="${u5%%.*}"
    u7_int="${u7%%.*}"

    if ((u7_int >= CRIT_7D)); then
        notify "critical" "Claude Revolver" "Account '$name' 7-day usage at ${u7}%% — near limit!"
    elif ((u7_int >= WARN_7D)); then
        notify "normal" "Claude Revolver" "Account '$name' 7-day usage at ${u7}%%"
    fi

    if ((u5_int >= WARN_5H)); then
        notify "normal" "Claude Revolver" "Account '$name' 5-hour usage at ${u5}%%"
    fi

    log "polled '$name': 5h=${u5}% 7d=${u7}%"
done

# Write cache atomically
tmp="${USAGE_CACHE}.tmp.$$"
printf '%s' "$cache" | jq '.' > "$tmp"
chmod 600 "$tmp"
mv -f "$tmp" "$USAGE_CACHE"

log "cache updated"
